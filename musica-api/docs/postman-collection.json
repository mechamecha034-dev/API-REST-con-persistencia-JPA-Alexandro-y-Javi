{
  "info": {
    "name": "Musica API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "admin",
        "type": "string"
      },
      {
        "key": "password",
        "value": "admin123",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Listar artistas",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/artistas"
      }
    },
    {
      "name": "Buscar artistas por nombre",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/artistas/buscar?nombre=rosa&sortBy=nombre&order=asc"
      }
    },
    {
      "name": "Crear artista",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Aitana\",\n  \"pais\": \"Espana\",\n  \"generoMusical\": \"Pop\",\n  \"anioDebut\": 2017,\n  \"activo\": true\n}"
        },
        "url": "{{baseUrl}}/api/v1/artistas"
      }
    },
    {
      "name": "Listar canciones",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/canciones"
      }
    },
    {
      "name": "Buscar canciones",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/canciones/buscar?titulo=mal&sortBy=duracion&order=desc"
      }
    },
    {
      "name": "Canciones por artista",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/canciones/artista/1"
      }
    },
    {
      "name": "Contador por artista",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/canciones/artista/1/contador"
      }
    },
    {
      "name": "Crear cancion",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Nueva cancion\",\n  \"artista\": {\n    \"id\": 1\n  },\n  \"album\": \"Demo\",\n  \"duracion\": 180\n}"
        },
        "url": "{{baseUrl}}/api/v1/canciones"
      }
    },
    {
      "name": "Listar playlists",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/playlists"
      }
    },
    {
      "name": "Playlists por artista",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/playlists/artista/1"
      }
    },
    {
      "name": "Crear playlist",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Entrenamiento\",\n  \"descripcion\": \"Canciones con energia\",\n  \"publica\": true\n}"
        },
        "url": "{{baseUrl}}/api/v1/playlists"
      }
    },
    {
      "name": "Anadir cancion a playlist",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/api/v1/playlists/1/canciones/1"
      }
    }
  ]
}
